<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  Manifeste v2 (COMPLEMENT DISTINCT, pour test avant remplacement de la v1).
  Nouveautes par rapport a la v1 :
    - Bouton "Prefixes" disponible aussi a la creation de REUNION (rendez-vous).
    - Bandeau de rappel automatique a chaque nouveau message ET nouvelle reunion.
  GUID et DisplayName differents de la v1 => les deux complements coexistent.
  Fichiers heberges (deja en ligne) : taskpane.html/js, commands.html, launchevent.js, assets/.
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <Id>d06aa8df-e113-4fa6-b436-a9ac106637f6</Id>
  <Version>2.0.0.0</Version>
  <ProviderName>Le Train</ProviderName>
  <DefaultLocale>fr-FR</DefaultLocale>
  <DisplayName DefaultValue="Préfixes d'objet (v2 test)" />
  <Description DefaultValue="Insère un préfixe normalisé dans l'objet des messages et des réunions, avec rappel automatique." />
  <IconUrl DefaultValue="https://le-train.github.io/Objet-mail/assets/icon-64.png" />
  <HighResolutionIconUrl DefaultValue="https://le-train.github.io/Objet-mail/assets/icon-128.png" />
  <SupportUrl DefaultValue="https://le-train.github.io/Objet-mail/taskpane.html" />

  <AppDomains>
    <AppDomain>https://le-train.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3" />
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://le-train.github.io/Objet-mail/taskpane.html" />
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit" />
    <Rule xsi:type="ItemIs" ItemType="Appointment" FormType="Edit" />
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="commandsUrl" />

          <!-- Surface : composition d'un MESSAGE -->
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgGroup">
                <Label resid="groupLabel" />
                <Control xsi:type="Button" id="msgOpenPane">
                  <Label resid="btnLabel" />
                  <Supertip>
                    <Title resid="btnTitle" />
                    <Description resid="btnDesc" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16" />
                    <bt:Image size="32" resid="icon32" />
                    <bt:Image size="80" resid="icon80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="taskpaneUrl" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

          <!-- Surface : composition d'une REUNION / rendez-vous -->
          <ExtensionPoint xsi:type="AppointmentOrganizerCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="apptGroup">
                <Label resid="groupLabel" />
                <Control xsi:type="Button" id="apptOpenPane">
                  <Label resid="btnLabel" />
                  <Supertip>
                    <Title resid="btnTitle" />
                    <Description resid="btnDesc" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16" />
                    <bt:Image size="32" resid="icon32" />
                    <bt:Image size="80" resid="icon80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="taskpaneUrl" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="icon16" DefaultValue="https://le-train.github.io/Objet-mail/assets/icon-16.png" />
        <bt:Image id="icon32" DefaultValue="https://le-train.github.io/Objet-mail/assets/icon-32.png" />
        <bt:Image id="icon80" DefaultValue="https://le-train.github.io/Objet-mail/assets/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="taskpaneUrl" DefaultValue="https://le-train.github.io/Objet-mail/taskpane.html" />
        <bt:Url id="commandsUrl" DefaultValue="https://le-train.github.io/Objet-mail/commands.html" />
        <bt:Url id="jsRuntimeUrl" DefaultValue="https://le-train.github.io/Objet-mail/launchevent.js" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="groupLabel" DefaultValue="Normalisation" />
        <bt:String id="btnLabel" DefaultValue="Préfixes" />
        <bt:String id="btnTitle" DefaultValue="Préfixes d'objet" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="btnDesc" DefaultValue="Ouvre le volet pour insérer un préfixe normalisé dans l'objet." />
      </bt:LongStrings>
    </Resources>

    <!-- Activation evenementielle : bandeau automatique (message + reunion) -->
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">
      <Requirements>
        <bt:Sets DefaultMinVersion="1.10">
          <bt:Set Name="Mailbox" />
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="MailHost">
          <Runtimes>
            <Runtime resid="commandsUrl">
              <Override type="javascript" resid="jsRuntimeUrl" />
            </Runtime>
          </Runtimes>
          <DesktopFormFactor>
            <FunctionFile resid="commandsUrl" />
            <ExtensionPoint xsi:type="LaunchEvent">
              <LaunchEvents>
                <LaunchEvent Type="OnNewMessageCompose" FunctionName="onNewMessageComposeHandler" />
                <LaunchEvent Type="OnNewAppointmentOrganizer" FunctionName="onNewAppointmentOrganizerHandler" />
              </LaunchEvents>
              <SourceLocation resid="commandsUrl" />
            </ExtensionPoint>
          </DesktopFormFactor>
        </Host>
      </Hosts>

      <Resources>
        <bt:Images>
          <bt:Image id="icon16" DefaultValue="https://le-train.github.io/Objet-mail/assets/icon-16.png" />
        </bt:Images>
        <bt:Urls>
          <bt:Url id="commandsUrl" DefaultValue="https://le-train.github.io/Objet-mail/commands.html" />
          <bt:Url id="jsRuntimeUrl" DefaultValue="https://le-train.github.io/Objet-mail/launchevent.js" />
        </bt:Urls>
      </Resources>
    </VersionOverrides>
  </VersionOverrides>
</OfficeApp>
